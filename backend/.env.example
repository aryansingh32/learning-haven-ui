PORT=5000
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# WhatsApp Cloud API (Meta Business)
# Get these from https://developers.facebook.com > WhatsApp > Getting Started
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token
# This token is sent by your external cron scheduler at webhook registration
WHATSAPP_VERIFY_TOKEN=dsaos_webhook_secret

# Cron secret (used by external schedulers like cron-job.org or Vercel Cron)
# Include this as x-cron-secret header in your cron HTTP requests
CRON_SECRET=your_strong_random_cron_secret

# Payment
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379
