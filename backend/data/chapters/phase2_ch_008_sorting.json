            "question": "Merge sort time complexity is",
            "options": [
              "O(n log n)",
              "O(n^2)",
              "O(n)"
            ],
            "correctAnswer": "O(n log n)",
            "explanation": "Divide and conquer leads to n log n."
          },
          {
            "question": "Quick sort worst case is",
            "options": [
              "O(n^2)",
              "O(n log n)",
              "O(log n)"
            ],
            "correctAnswer": "O(n^2)",
            "explanation": "Bad pivot splits cause quadratic behavior."
          },
          {
            "question": "Stable sort means",
            "options": [
              "equal elements keep order",
              "sort is fast",
              "sort uses O(1) space"
            ],
            "correctAnswer": "equal elements keep order",
            "explanation": "Stability preserves original ordering."
          }
        ]
      }
